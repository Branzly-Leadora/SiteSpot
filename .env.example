# ── Zkopíruj tento soubor jako .env a vyplň hodnoty ──────
# cp .env.example .env

# Port serveru (default: 3000)
PORT=3000

# ── SMTP nastavení ────────────────────────────────────────
# Gmail příklad:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=tvuj@gmail.com
#   SMTP_PASS=xxxx xxxx xxxx xxxx   ← App Password (ne heslo k účtu!)
#
# Wedos / Forpsi příklad:
#   SMTP_HOST=smtp.wedos.net
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=info@sitespot.cz
#   SMTP_PASS=heslo

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tvuj@gmail.com
SMTP_PASS=app_password_zde

# Kam přijdou zprávy z formuláře (pokud prázdné, použije se SMTP_USER)
MAIL_TO=business@sitespot.cz

# ── AI ukázky (živý chatbot + vytěžování dokumentů) ───────
# Volitelné. Když VYPLNÍŠ klíč, demo na /automatizace.html volá doopravdy
# Claude. Když necháš PRÁZDNÉ, demo běží na připravených odpovědích
# (vypadá stejně přesvědčivě, jen se nikam nevolá).
# Klíč získáš na console.anthropic.com (placené per-use, oddělené od Pro/Max).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

